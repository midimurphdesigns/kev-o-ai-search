# Required
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Rate limit + budget cap
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KEV_O_DAILY_USD_CAP=5

# Owner bypass — set to a long random string; pass via ?admin=<value>
# to drop a cookie that bypasses rate limits during testing.
KEV_O_ADMIN_KEY=

# GitHub fine-grained PAT used ONLY to clone the private blog content repo
# (midimurphdesigns/blog-portfolio-v3) during vercel-build.sh. Public OSS
# README fetches use anonymous access — see scripts/build-corpus.ts.
# Token scope: Contents:Read on blog-portfolio-v3 only.
GITHUB_TOKEN=

# Source dir for content (build-corpus script reads this).
# Default: sibling repo on Desktop; CI sets it to a checkout path.
BLOG_REPO_PATH=../blog-portfolio-v3
